            <column name="set_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="profile_collection_set_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey columnNames="profile_collection_set_id, set_id" tableName="rel_profile_collection_set__set"/>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->

