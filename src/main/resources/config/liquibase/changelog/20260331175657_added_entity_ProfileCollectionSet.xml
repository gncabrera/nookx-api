    <!--
        Added the entity ProfileCollectionSet.
    -->
    <changeSet id="20260331175657-1" author="jhipster">
        <createTable tableName="profile_collection_set">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owned" type="boolean">
                <constraints nullable="true" />
            </column>
            <column name="wanted" type="boolean">
                <constraints nullable="true" />
            </column>
            <column name="date_added" type="date">
                <constraints nullable="true" />
            </column>
            <column name="collection_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
    </changeSet>

    <changeSet id="20260331175657-1-relations" author="jhipster">

