<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity MegaSet.
    -->
    <changeSet id="20260331175643-1" author="jhipster">
        <createTable tableName="mega_set">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="set_number" type="varchar(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="ux_mega_set__set_number" />
            </column>
            <column name="release_date" type="date">
                <constraints nullable="true" />
            </column>
            <column name="notes" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="name_en" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="name_es" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="name_de" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="name_fr" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="description_en" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="description_es" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="description_de" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="description_fr" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="attributes" type="${blobType}">
                <constraints nullable="true" />
            </column>
            <column name="attributes_content_type" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="type_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->

</databaseChangeLog>
