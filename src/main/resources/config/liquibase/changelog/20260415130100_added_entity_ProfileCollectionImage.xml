    <!--
        Added the entity ProfileCollectionImage.
    -->
    <changeSet id="20260415130100-1" author="nookx">
        <createTable tableName="profile_collection_image">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="profile_collection_id" type="bigint">
